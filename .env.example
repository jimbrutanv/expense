# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Secret used to sign auth tokens. CHANGE THIS in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# How long a login session stays valid.
TOKEN_TTL=12h

# ── First-run admin (super admin) ───────────────────────
# Created automatically the first time the server boots.
ADMIN_EMAIL=admin@ptracker.local
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Administrator

# Seed the bundled "Project Tracker-Demo.xlsx" as a project on first run.
SEED_DEMO=true

# ── Backups ─────────────────────────────────────────────
# Cron expression for automatic backups (default: every day at 02:00).
AUTO_BACKUP_CRON=0 2 * * *
# How many automatic backups to keep before old ones are pruned.
BACKUP_RETENTION=14

# ── Locale ──────────────────────────────────────────────
# Default currency used for new projects (admin can override per project).
DEFAULT_CURRENCY=INR
DEFAULT_LOCALE=en-IN
